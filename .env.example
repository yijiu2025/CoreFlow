# --- 系统基础配置 ---
NODE_ENV=development
PORT=3000

# --- 数据库配置 (SQL) ---
# DB_TYPE 可选: mysql, postgres, sqlite
DB_TYPE=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=root
DB_PASS=your_password

# --- Redis 配置 ---
# 开启 Redis 混合存储加速（设为 true 并配置 HOST 以启用）
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_TLS=false

# --- 安全与加密 ---
# 用于 JWT 签名的密钥，必须使用强随机字符串（生产环境强制校验）
APP_SECRET=change-me-to-a-random-string
SESSION_SECRET=change-me-to-a-random-string
FIREWALL_SECRET=change-me-to-a-random-string

# --- CORS 配置 ---
# 生产环境允许的跨域来源（逗号分隔），开发环境留空则允许所有
CORS_ORIGINS=https://your-domain.com

# --- SMTP 邮件配置 ---
SMTP_SERVER=smtp.163.com
SMTP_PORT=465
SMTP_USER=your_email@163.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM="Your App <your_email@163.com>"
SMTP_USE_SSL=true

# --- 业务逻辑开关 ---
# 是否在启动时自动同步数据库表结构 (开发环境建议开启)
DB_SYNC=true

# --- Token TTL ---
ACCESS_TOKEN_TTL=600
REFRESH_TOKEN_TTL=86400
ID_TOKEN_TTL=3600
AUTH_CODE_TTL=600