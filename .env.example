# ================================================================
# 环境配置文件模板
# 复制此文件为 .env 并修改对应值
# ================================================================

# --- 系统基础配置 ---
# 运行环境：development / production / test
NODE_ENV=development
# 服务监听端口
PORT=3000
# 慢请求告警阈值（毫秒），超过此值记录警告日志（默认 2000）
# SLOW_REQUEST_THRESHOLD=2000

# --- 数据库配置 (SQL) ---
# 数据库类型：mysql / postgres / sqlite
DB_TYPE=mysql
# 数据库主机地址
DB_HOST=127.0.0.1
# 数据库端口
DB_PORT=3306
# 数据库名称
DB_NAME=your_database_name
# 数据库用户名
DB_USER=root
# 数据库密码
DB_PASS=your_password
# 连接池最大连接数（默认 10）
# DB_POOL_MAX=10
# 连接池最小连接数（默认 2）
# DB_POOL_MIN=2
# 获取连接超时毫秒数（默认 30000）
# DB_POOL_ACQUIRE=30000
# 空闲连接释放毫秒数（默认 10000）
# DB_POOL_IDLE=10000

# --- Redis 配置 ---
# 是否启用 Redis（true/false），启用后用于 Session 存储、限流、Nonce 去重等
REDIS_ENABLED=false
# Redis 主机地址
REDIS_HOST=127.0.0.1
# Redis 端口
REDIS_PORT=6379
# Redis 密码（留空表示无密码）
REDIS_PASSWORD=
# 是否启用 TLS 加密连接（true/false）
# REDIS_TLS=false

# --- 安全与加密 ---
# JWT 签名密钥（必须使用强随机字符串，生产环境强制校验）
APP_SECRET=change-me-to-a-random-string
# Session Cookie HMAC 签名密钥（用于防篡改）
SESSION_SECRET=change-me-to-a-random-string
# 防火墙密钥（用于签名验证）
FIREWALL_SECRET=change-me-to-a-random-string
# JWT 模式开关（默认关闭，使用 Session Cookie 认证；开启后使用 JWT access_token）
JWT_ENABLED=false
# 每用户最大 refresh token 数量（超出时删除最久未刷新的）
MAX_REFRESH_TOKENS=10

# --- CORS 跨域配置 ---
# 生产环境允许的跨域来源（逗号分隔），开发环境留空则允许所有
# CORS_ORIGINS=https://your-domain.com

# --- SMTP 邮件配置 ---
# SMTP 服务器地址
SMTP_SERVER=smtp.163.com
# SMTP 端口（SSL: 465, TLS: 587）
SMTP_PORT=465
# SMTP 用户名
SMTP_USER=your_email@163.com
# SMTP 授权码/密码
SMTP_PASSWORD=your_smtp_password
# 发件人显示名称
SMTP_FROM="Your App <your_email@163.com>"
# 是否使用 SSL（端口 465 必选 true）
SMTP_USE_SSL=true

# --- 业务逻辑开关 ---
# 启动时是否自动同步表结构（true/false）
# 仅限首次开发环境建表使用，生产环境必须用 npm run migrate
DB_SYNC=false

# --- Token 有效期（秒） ---
# Access Token 有效期（默认 10 分钟）
ACCESS_TOKEN_TTL=600
# Refresh Token 有效期（默认 1 天）
REFRESH_TOKEN_TTL=86400
# ID Token 有效期（默认 1 小时）
ID_TOKEN_TTL=3600
# 授权码有效期（默认 10 分钟）
AUTH_CODE_TTL=600

# ================================================================
# 验证模块配置
# ================================================================

# --- 图形验证码 ---
# 验证码字符数（默认 4）
CAPTCHA_SIZE=4
# 干扰线数量（默认 3，越大越难识别）
CAPTCHA_NOISE=3
# 验证码有效期秒数（默认 600 = 10 分钟）
CAPTCHA_TTL=600
# 验证通过后延长有效期秒数（默认 300 = 5 分钟）
CAPTCHA_EXTEND_TTL=300

# --- 短信验证码 ---
# 短信服务商：aliyun / tencent
SMS_PROVIDER=aliyun
# 阿里云/腾讯云 AccessKey ID
SMS_ACCESS_KEY_ID=
# 阿里云/腾讯云 AccessKey Secret
SMS_ACCESS_KEY_SECRET=
# 短信签名（需在服务商后台申请）
SMS_SIGN_NAME=
# 短信模板编码（需在服务商后台申请）
SMS_TEMPLATE_CODE=
# 验证码长度（默认 6 位）
SMS_CODE_LENGTH=6
# 验证码有效期秒数（默认 300 = 5 分钟）
SMS_CODE_TTL=300
# 发送频率限制秒数（默认 60，即同一号码 60 秒内只能发一次）
SMS_RATE_LIMIT=60

# --- 人机验证 ---
# 服务商：google / hcaptcha
RECAPTCHA_PROVIDER=google
# reCAPTCHA/hCaptcha 密钥（从服务商后台获取）
RECAPTCHA_SECRET_KEY=
# reCAPTCHA/hCaptcha 站点密钥（前端使用）
RECAPTCHA_SITE_KEY=
# reCAPTCHA v3 最低分数（0.0-1.0，默认 0.5，低于此分数视为机器人）
RECAPTCHA_MIN_SCORE=0.5

# --- 滑块验证码 ---
# 滑块位置容差像素数（默认 5，即用户拖动位置与目标相差 5px 内算通过）
SLIDER_TOLERANCE=5
# 滑块验证码有效期秒数（默认 300 = 5 分钟）
SLIDER_TTL=300

# --- 二维码扫码 ---
# 二维码有效期秒数（默认 300 = 5 分钟）
QRCODE_TTL=300
# PC 端轮询扫码状态间隔毫秒数（默认 2000 = 2 秒）
QRCODE_POLL_INTERVAL=2000

# --- 验证通用 ---
# 通用频率限制秒数（默认 60）
VERIFY_RATE_LIMIT=60
# 通用验证码有效期秒数（默认 600 = 10 分钟）
VERIFY_CODE_TTL=600

# ================================================================
# 防火墙配置（可选，有默认值）
# ================================================================
# FW_SCAN_THRESHOLD=10          # 扫描检测阈值
# FW_BLACKLIST_DURATION=3600    # 封禁时长（秒）
# FW_RATE_LIMIT=60              # 全局限频（请求/分钟）
# FW_BRUTE_LIMIT=5              # 暴力破解阈值
# FW_LOCK_TIME=900              # 账号锁定时长（秒）
# FW_MAX_CONN=100               # 最大并发连接数
# FW_BOT_PATTERNS=              # 追加 Bot 检测模式（逗号分隔）
# FW_SENSITIVE_PATHS=           # 敏感路径（逗号分隔，覆盖默认值）
# FW_GEO_FILTER=false           # 启用地理围栏（true/false）
