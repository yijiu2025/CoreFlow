# --- 系统基础配置 ---
NODE_ENV=development
PORT=3000

# --- 数据库配置 (SQL) ---
# DB_TYPE 可选: mysql, postgres, sqlite
DB_TYPE=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=root
DB_PASS=your_password

# --- Redis 配置 ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- 安全与加密 ---
# 用于 JWT 签名的密钥，随便写一串长字符
APP_SECRET=your_super_secret_key_2026

# --- 业务逻辑开关 ---
# 是否在启动时自动同步数据库表结构 (开发环境建议开启)
DB_SYNC=true

FIREWALL_SECRET = your_super_secret_key_2026

ACCESS_TOKEN_TTL=600
REFRESH_TOKEN_TTL=86400
ID_TOKEN_TTL=3600
AUTH_CODE_TTL=600
SESSION_SECRET=change-this-in-production-secret-key-2024