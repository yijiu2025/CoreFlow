<!-- src/views/consent.ejs -->
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>授权同意 — OAuth 2.1</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0a0a0a; --surface: #141414; --border: #2a2a2a;
      --accent: #c8ff00; --text: #e8e8e8; --text-muted: #666;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'DM Mono', monospace; background: var(--bg); color: var(--text);
      min-height: 100vh; display: flex; align-items: center; justify-content: center;
    }
    .container { width: 100%; max-width: 460px; padding: 0 24px; }
    .brand {
      font-family: 'Instrument Serif', serif; font-size: 14px;
      letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent);
      margin-bottom: 48px;
    }
    h1 {
      font-family: 'Instrument Serif', serif; font-size: 28px;
      font-weight: 400; margin-bottom: 24px;
    }
    .scope-card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 4px; padding: 20px; margin-bottom: 32px;
    }
    .scope-item {
      display: flex; align-items: center; gap: 12px;
      padding: 10px 0; border-bottom: 1px solid var(--border);
    }
    .scope-item:last-child { border-bottom: none; }
    .scope-icon { color: var(--accent); font-size: 16px; }
    .scope-name { font-size: 13px; font-weight: 500; }
    .scope-desc { font-size: 11px; color: var(--text-muted); }
    .actions { display: flex; gap: 12px; }
    .btn {
      flex: 1; padding: 14px; border-radius: 4px;
      font-family: 'DM Mono', monospace; font-size: 13px;
      font-weight: 500; letter-spacing: 0.1em; cursor: pointer;
      transition: opacity 0.2s; border: none;
    }
    .btn-allow { background: var(--accent); color: #000; }
    .btn-deny {
      background: var(--surface); color: var(--text);
      border: 1px solid var(--border);
    }
    .btn:hover { opacity: 0.85; }
    input[type="hidden"] { display: none; }
  </style>
</head>
<body>
  <div class="container">
    <div class="brand">OAuth 2.1 Authorization Center</div>
    <h1>Authorize access</h1>
    <p style="color:var(--text-muted);font-size:13px;margin-bottom:24px">
      <strong style="color:var(--accent)"><%= client_name %></strong> is requesting the following permissions:
    </p>

    <div class="scope-card">
      <% scope.split(' ').forEach(function(s) { %>
        <div class="scope-item">
          <span class="scope-icon">&#9679;</span>
          <div>
            <div class="scope-name"><%= s %></div>
            <div class="scope-desc">
              <% if (s === 'openid') { %>Access your identity<% } %>
              <% if (s === 'profile') { %>Access your profile info<% } %>
              <% if (s === 'email') { %>Access your email address<% } %>
              <% if (s === 'api:read') { %>Read data from the API<% } %>
              <% if (s === 'api:write') { %>Write data to the API<% } %>
            </div>
          </div>
        </div>
      <% }); %>
    </div>

    <div class="actions">
      <form method="POST" action="/authorize/consent" style="flex:1">
        <input type="hidden" name="sessionId" value="<%= sessionId %>">
        <input type="hidden" name="user_id" value="<%= user_id %>">
        <input type="hidden" name="action" value="deny">
        <button type="submit" class="btn btn-deny">Deny</button>
      </form>
      <form method="POST" action="/authorize/consent" style="flex:1">
        <input type="hidden" name="sessionId" value="<%= sessionId %>">
        <input type="hidden" name="user_id" value="<%= user_id %>">
        <input type="hidden" name="action" value="allow">
        <button type="submit" class="btn btn-allow">Allow</button>
      </form>
    </div>
  </div>
</body>
</html>
