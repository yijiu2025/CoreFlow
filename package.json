{
  "name": "nodeservers",
  "version": "1.0.0",
  "description": "公众号：柒染靓月",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "chcp 65001 >nul 2>&1 && nodemon --env-file=.env index.js",
    "start": "node --env-file=.env.production index.js",
    "migrate": "node --env-file=.env src/db/migrate.js",
    "setup:admin": "node --env-file=.env scripts/setup-superadmin.js",
    "revoke:admin": "node --env-file=.env scripts/revoke-superadmin.js",
    "cli": "node --env-file=.env scripts/cli.js",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "audit": "npm audit --production",
    "audit:fix": "npm audit fix --production",
    "prepare": "husky",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "lint-staged": {
    "src/**/*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [],
  "author": "qirly",
  "license": "GPL",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "geoip-lite": "^2.0.1",
    "jsonwebtoken": "^9.0.3",
    "lodash-es": "^4.18.1",
    "mysql2": "^3.22.1",
    "nodemailer": "^8.0.7",
    "pino-pretty": "^13.1.3",
    "redis": "^5.12.1",
    "sequelize": "^6.37.8",
    "sharp": "^0.34.5",
    "svg-captcha": "^1.4.0",
    "umzug": "^3.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^17.0.7",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "vitepress": "^1.6.4",
    "vue": "^3.5.38"
  }
}
